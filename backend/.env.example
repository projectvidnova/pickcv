# PickCV Backend Environment Configuration
# Copy this to .env and fill in your values

# ============= ENVIRONMENT =============
ENVIRONMENT=development  # Set to 'production' for production deployment
DEBUG=true

# ============= DATABASE =============
# Production: Use managed PostgreSQL (Cloud SQL, RDS, etc.)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pickcv

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ============= SECURITY =============
# CRITICAL: Generate a strong secret key for production
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-generated-secret-key-here

# Password requirements
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# ============= CORS =============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://www.pickcv.com,https://pickcv.com

# ============= RATE LIMITING =============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============= EXTERNAL APIS =============
# Google Gemini API Key (for resume analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# ============= FILE UPLOADS =============
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,doc,txt

# ============= LOGGING =============
LOG_LEVEL=DEBUG  # INFO for production
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============= HTTPS & SECURITY HEADERS =============
ENABLE_HTTPS_ONLY=true
HSTS_MAX_AGE=31536000

# ============= OPTIONAL: Redis (for caching & sessions) =============
REDIS_URL=redis://localhost:6379/0

# ============= OPTIONAL: Email Service (for notifications) =============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============= OPTIONAL: File Storage (Google Cloud Storage or AWS S3) =============
# GCS_BUCKET_NAME=pickcv-resumes
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_S3_BUCKET=pickcv-resumes
